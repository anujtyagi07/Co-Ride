# ───────────────────────────────────────────────────────────────────────────
# Co-Ride Frontend Environment Configuration
# Copy this file to `.env` (or `.env.production` for production builds).
# All variables MUST be prefixed with VITE_ to be exposed to the client.
# ───────────────────────────────────────────────────────────────────────────

# ─── API base URL ───────────────────────────────────────────────────────────
# Local dev:        /api          (uses Vite proxy → http://localhost:5001)
# Vercel mono:      /api          (same domain — no change needed)
# Split deploy:     https://coride-api.onrender.com/api
VITE_API_URL=/api

# ─── Real-time chat ─────────────────────────────────────────────────────────
# Leave VITE_SOCKET_URL empty to use HTTP polling (works on all platforms).
# Set to a Socket.IO URL only on a long-running host that has Socket.IO enabled
# (e.g. ENABLE_SOCKET=true on Render/Railway).
# Example: VITE_SOCKET_URL=https://coride-api.onrender.com
# VITE_SOCKET_URL=

# Polling interval in ms for chat updates when Socket.IO is unavailable.
# Lower = snappier, more API calls. Higher = cheaper, laggier.
VITE_CHAT_POLL_MS=3000

# ─── Razorpay (payments) ────────────────────────────────────────────────────
# Public key only — never put your secret here, it belongs in backend/.env
# Test: rzp_test_xxxxx  Live: rzp_live_xxxxx
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id

# ─── Google Maps (optional) ─────────────────────────────────────────────────
# Only needed for Google Maps components. The default TripDetail map uses
# OpenStreetMap + Leaflet and does NOT require this key.
# Get one at: https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ─── App base path ──────────────────────────────────────────────────────────
# Sub-path if hosted under a sub-directory (e.g. GitHub Pages project sites).
# Leave as '/' for Vercel root or custom domains.
VITE_BASE_PATH=/
