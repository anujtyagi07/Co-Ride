# ───────────────────────────────────────────────────────────────────────────
# Co-Ride Backend Environment Configuration
# Copy this file to `.env` and fill in real values.
# ───────────────────────────────────────────────────────────────────────────

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# Deployment mode — controls how index.js boots.
#   serverless    — exports the bare Express app (Vercel, AWS Lambda, Netlify fns)
#   long-running  — boots HTTP server with optional Socket.IO (Render, Railway, local)
# Auto-detected: VERCEL=1 → serverless, otherwise → long-running.
# Override only if you need to.
# DEPLOYMENT_MODE=long-running

# Set to 'true' on a long-running host to enable Socket.IO real-time chat.
# On serverless this is ignored (chat uses HTTP polling).
# ENABLE_SOCKET=false

# ─── Database ───────────────────────────────────────────────────────────────
# Local dev:        mongodb://localhost:27017/co-ride
# Production:       mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/co-ride
MONGODB_URI=mongodb://localhost:27017/co-ride

# Connection pool size for serverless. 1-10 is typical.
MONGO_POOL_SIZE=10

# ─── JWT ────────────────────────────────────────────────────────────────────
# Generate strong random strings in production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-too-must-be-different-from-jwt-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins. Use '*' to allow all
# (not recommended in production). The app also automatically allows
# *.vercel.app, *.onrender.com, *.up.railway.app, *.netlify.app previews.
CLIENT_URL=http://localhost:3000

# ─── Upload limits ──────────────────────────────────────────────────────────
# Max request body size. Default is 4 MB to stay safely under Vercel's
# 4.5 MB hobby-plan cap. Increase on Render/Railway if needed.
MAX_UPLOAD_SIZE_MB=4

# ─── Rate limiting ──────────────────────────────────────────────────────────
# Max requests per 15 min per IP for the general API.
RATE_LIMIT_MAX=100

# ─── Razorpay (payments) ────────────────────────────────────────────────────
# Sign up at https://dashboard.razorpay.com → Settings → API Keys
# Test keys start with rzp_test_, live keys with rzp_live_
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# ─── Google Maps (optional) ─────────────────────────────────────────────────
# Only needed for Google Maps directions / places autocomplete. The app uses
# OpenStreetMap + Leaflet by default and does NOT require this key.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ─── Cloudinary (optional media storage) ────────────────────────────────────
# If unset, document uploads are stored as base64 in the database (fine for
# dev, not recommended for production at scale).
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Email (SMTP) ───────────────────────────────────────────────────────────
# Required for OTP emails, password reset, booking confirmations.
# Gmail users: enable 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=noreply@coride.com
